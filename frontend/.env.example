# Backend API target (used by Vite dev server proxy in `vite dev` only)
VITE_API_TARGET=http://localhost:8000

# Backend API origin baked into the production build.
# Leave unset for dev (relative paths flow through the Vite proxy).
# Set to the absolute backend URL for production builds, e.g. https://api.example.com
# VITE_API_BASE_URL=https://api.example.com

# Supabase (required for auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Feature flags (optional)
# VITE_FEATURE_BROKER=true
