# Flywheel v2 configuration
# Copy to .env and adjust as needed

# Backend selector: "flatfile" (default) or "postgres"
FLYWHEEL_BACKEND=flatfile

# PostgreSQL connection string (only used when FLYWHEEL_BACKEND=postgres)
DATABASE_URL=postgresql+asyncpg://flywheel:flywheel@localhost:5432/flywheel

# Debug mode (enables SQL echo, verbose logging)
DEBUG=true

# CORS allowed origins (JSON array)
CORS_ORIGINS=["http://localhost:5173"]
